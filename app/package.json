    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "node-html-markdown": "^2.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "survey-core": "^2.5.32",
    "survey-creator-core": "^2.5.32",
    "survey-creator-react": "^2.5.32",
    "survey-react-ui": "^2.5.32",
