{
  "name": "waic-side-events-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && pnpm build:server",
    "build:server": "vite build --ssr src/server.prod.ts --outDir dist-server",
    "preview": "vite preview",
    "start": "node dist-server/server.prod.js",
    "typecheck": "tsc -b --noEmit",
    "cf:preview": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
